generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ADVISER
  SUPER_ADMIN
}

model WealthGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users                    User[]
  advisers                 Adviser[]
  clients                  Client[]
  taxonomies               Taxonomy[]
  cmaSets                  CMASet[]
  fundApprovals            PMFundApproval[]
  taxonomyLiquidityDefaults TaxonomyLiquidityDefault[]
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  role           Role
  wealthGroupId  String?
  createdAt      DateTime @default(now())

  wealthGroup                WealthGroup?            @relation(fields: [wealthGroupId], references: [id])
  adviser                    Adviser?
  taxonomies                 Taxonomy[]
  stressScenarios            StressScenario[]
  stressRuns                 StressRun[]
  cmaSets                    CMASet[]
  liquidityStressScenarios   LiquidityStressScenario[]
  liquidityStressRuns        LiquidityStressRun[]
}

model Adviser {
  id             String   @id @default(cuid())
  userId         String   @unique
  firmName       String
  wealthGroupId  String?
  createdAt      DateTime @default(now())

  user                   User                      @relation(fields: [userId], references: [id])
  wealthGroup            WealthGroup?              @relation(fields: [wealthGroupId], references: [id])
  clients                Client[]
  saas                   SAA[]
  liquidityOverrides     AdviserLiquidityOverride[]
}

model Client {
  id             String   @id @default(cuid())
  adviserId      String
  wealthGroupId  String?
  name           String
  createdAt      DateTime @default(now())

  adviser                Adviser              @relation(fields: [adviserId], references: [id])
  wealthGroup            WealthGroup?         @relation(fields: [wealthGroupId], references: [id])
  accounts               Account[]
  clientSAA              ClientSAA?
  clientSleeve           ClientSleeve?
  orders                 Order[]
  stressResults          StressResult[]
  rebalancePlans         RebalancePlan[]
  cmaSelection           ClientCMASelection?
  liquidityStressResults LiquidityStressResult[]
}

// ── Platform / Holdings ─────────────────────────────────

enum Platform {
  HUB24
  NETWEALTH
  CFS
}

enum ProductType {
  DIRECT
  MANAGED_PORTFOLIO
  FUND
  ETF
}

model Account {
  id          String   @id @default(cuid())
  clientId    String
  platform    Platform
  accountName String
  createdAt   DateTime @default(now())

  client   Client    @relation(fields: [clientId], references: [id])
  holdings Holding[]
}

model Product {
  id        String      @id @default(cuid())
  name      String
  type      ProductType
  createdAt DateTime    @default(now())

  holdings              Holding[]
  lookthroughUnderlying LookthroughHolding[] @relation("UnderlyingProduct")
  taxonomyMaps          ProductTaxonomyMap[]
  sleeveLiquidPositions SleeveLiquidPosition[]
  recommendationLegs    SleeveRecommendationLeg[]
  orders                Order[]
  rebalanceTrades       RebalanceTrade[]
  liquidityOverride        ProductLiquidityOverride?
  adviserLiquidityOverrides AdviserLiquidityOverride[]
}

model Holding {
  id         String   @id @default(cuid())
  accountId  String
  productId  String
  marketValue Float
  units      Float?
  price      Float?
  asAtDate   DateTime @default(now())

  account              Account              @relation(fields: [accountId], references: [id])
  product              Product              @relation(fields: [productId], references: [id])
  lookthroughHoldings  LookthroughHolding[]
}

model LookthroughHolding {
  id                    String @id @default(cuid())
  holdingId             String
  underlyingProductId   String
  underlyingMarketValue Float
  weight                Float

  holding            Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  underlyingProduct  Product @relation("UnderlyingProduct", fields: [underlyingProductId], references: [id])
}

// ── SAA ─────────────────────────────────────────────────

enum SAAScope {
  FIRM
  ADVISER
}

model SAA {
  id         String   @id @default(cuid())
  name       String
  taxonomyId String
  ownerScope SAAScope @default(ADVISER)
  adviserId  String?
  createdAt  DateTime @default(now())

  taxonomy    Taxonomy      @relation(fields: [taxonomyId], references: [id])
  adviser     Adviser?      @relation(fields: [adviserId], references: [id])
  allocations SAAAllocation[]
  clientSAAs  ClientSAA[]
  rebalancePlans RebalancePlan[]
}

model SAAAllocation {
  id           String @id @default(cuid())
  saaId        String
  nodeId       String
  targetWeight Float  // 0–1
  minWeight    Float  // 0–1
  maxWeight    Float  // 0–1

  saa  SAA          @relation(fields: [saaId], references: [id], onDelete: Cascade)
  node TaxonomyNode @relation(fields: [nodeId], references: [id])

  @@unique([saaId, nodeId])
}

model ClientSAA {
  id            String   @id @default(cuid())
  clientId      String
  saaId         String
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  saa    SAA    @relation(fields: [saaId], references: [id])

  @@unique([clientId])
}

// ── Taxonomy Mapping ─────────────────────────────────────

enum MappingScope {
  FIRM_DEFAULT
  ADVISER_OVERRIDE
  CLIENT_OVERRIDE
}

model ProductTaxonomyMap {
  id         String       @id @default(cuid())
  taxonomyId String
  productId  String
  nodeId     String
  scope      MappingScope @default(FIRM_DEFAULT)
  adviserId  String?
  clientId   String?
  createdAt  DateTime     @default(now())

  taxonomy Taxonomy     @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])
  node     TaxonomyNode @relation(fields: [nodeId], references: [id])

  @@unique([taxonomyId, productId, scope, adviserId, clientId])
}

// ── Taxonomy ────────────────────────────────────────────

enum TaxonomyNodeType {
  RISK
  LIQUIDITY
  ASSET_CLASS
  SUB_ASSET
}

model Taxonomy {
  id              String         @id @default(cuid())
  name            String
  description     String?
  wealthGroupId   String?
  createdAt       DateTime       @default(now())
  createdByUserId String

  wealthGroup  WealthGroup?         @relation(fields: [wealthGroupId], references: [id])
  createdBy    User                 @relation(fields: [createdByUserId], references: [id])
  nodes        TaxonomyNode[]
  productMaps  ProductTaxonomyMap[]
  saas         SAA[]
}

model TaxonomyNode {
  id         String           @id @default(cuid())
  taxonomyId String
  parentId   String?
  name       String
  nodeType   TaxonomyNodeType
  sortOrder  Int              @default(0)

  taxonomy        Taxonomy             @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  parent          TaxonomyNode?        @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children        TaxonomyNode[]       @relation("NodeTree")
  productMaps      ProductTaxonomyMap[]
  saaAllocations   SAAAllocation[]
  stressShocks     StressShock[]
  cmaAssumptions   CMAAssumption[]
  liquidityDefaults TaxonomyLiquidityDefault[]
}

// ── Private Markets ──────────────────────────────────────

enum PMFundStatus {
  OPEN
  CLOSED
}

enum LifecycleStage {
  FUNDRAISING
  INVESTING
  HARVESTING
  LIQUIDATING
}

enum PMTemplateStatus {
  ACTIVE
  RETIRED
}

enum CashflowEventType {
  CALL
  DISTRIBUTION
}

model PMProjectionTemplate {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  currency           String?
  paramsJson         String             @default("{}")
  callCurvePctJson   String             // JSON: cumulative % by month (0..1)
  distCurvePctJson   String             // JSON: cumulative % by month (0..1)
  status             PMTemplateStatus   @default(ACTIVE)
  createdAt          DateTime           @default(now())

  fundTruths              PMFundTruth[]
  commitmentScenarios     ClientCommitmentScenario[]
}

enum CloseType {
  FIRST
  SECOND
  FINAL
  OTHER
}

model PMFundTruth {
  id                     String          @id @default(cuid())
  fundId                 String          @unique
  defaultTemplateId      String?
  lifecycleStage         LifecycleStage?
  firstCloseDate         DateTime?
  investmentPeriodMonths Int?
  fundTermMonths         Int?
  extensionMonths        Int?
  updatedAt              DateTime        @updatedAt

  fund             PMFund                @relation(fields: [fundId], references: [id], onDelete: Cascade)
  defaultTemplate  PMProjectionTemplate? @relation(fields: [defaultTemplateId], references: [id])
}

model PMFundClose {
  id        String    @id @default(cuid())
  fundId    String
  closeType CloseType
  closeDate DateTime
  capitalRaised Float?
  notes     String?
  createdAt DateTime  @default(now())

  fund PMFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, closeDate])
}

model PMFundNAVPoint {
  id        String   @id @default(cuid())
  fundId    String
  navDate   DateTime
  navAmount Float
  currency  String   @default("AUD")
  createdAt DateTime @default(now())

  fund PMFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, navDate])
}

model PMFundCashflowEvent {
  id        String            @id @default(cuid())
  fundId    String
  type      CashflowEventType
  eventDate DateTime
  amount    Float?            // used for DISTRIBUTION legacy; nullable for CALL (use callPct)
  callPct   Float?            // 0..1 for CALL events (% of commitment)
  currency  String            @default("AUD")
  notes     String?
  createdAt DateTime          @default(now())

  fund PMFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, eventDate])
}

enum DistributionBasis {
  PRO_RATA_COMMITMENT
  PRO_RATA_PAIDIN
}

model PMFundDistributionEvent {
  id          String             @id @default(cuid())
  fundId      String
  eventDate   DateTime
  totalAmount Float
  currency    String             @default("AUD")
  basis       DistributionBasis  @default(PRO_RATA_COMMITMENT)
  notes       String?
  createdAt   DateTime           @default(now())

  fund        PMFund                        @relation(fields: [fundId], references: [id], onDelete: Cascade)
  allocations PMFundDistributionAllocation[]

  @@index([fundId, eventDate])
}

model PMFundDistributionAllocation {
  id                   String  @id @default(cuid())
  distributionEventId  String
  clientCommitmentId   String
  amount               Float
  pctOfCommitment      Float?  // informational: allocation / commitmentAmount
  createdAt            DateTime @default(now())

  distributionEvent PMFundDistributionEvent @relation(fields: [distributionEventId], references: [id], onDelete: Cascade)
  commitment        ClientCommitment        @relation(fields: [clientCommitmentId], references: [id], onDelete: Cascade)

  @@unique([distributionEventId, clientCommitmentId])
}

model PMFundKpiPoint {
  id      String   @id @default(cuid())
  fundId  String
  kpiDate DateTime
  tvpi    Float    // Total Value to Paid-In
  rvpi    Float    // Residual Value to Paid-In
  dpi     Float    // Distributions to Paid-In
  moic    Float    // Multiple on Invested Capital
  createdAt DateTime @default(now())

  fund PMFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([fundId, kpiDate])
}

model PMFund {
  id                     String         @id @default(cuid())
  name                   String
  vintageYear            Int?
  strategy               String?
  currency               String         @default("AUD")
  status                 PMFundStatus   @default(OPEN)
  lifecycleStage         LifecycleStage?
  firstCloseDate         DateTime?
  investmentPeriodMonths Int?
  fundTermMonths         Int?
  createdAt              DateTime       @default(now())

  approvals           PMFundApproval[]
  profile             PMFundProfile?
  truth               PMFundTruth?
  commitments         ClientCommitment[]
  closes              PMFundClose[]
  navPoints           PMFundNAVPoint[]
  cashflowEvents      PMFundCashflowEvent[]
  distributionEvents  PMFundDistributionEvent[]
  kpiPoints           PMFundKpiPoint[]
}

model PMFundProfile {
  id                     String @id @default(cuid())
  fundId                 String @unique
  projectedCallPctCurveJson  String // JSON array [{month, cumPct}]
  projectedDistPctCurveJson  String // JSON array [{month, cumPct}]

  fund PMFund @relation(fields: [fundId], references: [id], onDelete: Cascade)
}

model PMFundApproval {
  id             String   @id @default(cuid())
  fundId         String
  wealthGroupId  String?
  isApproved     Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())

  fund        PMFund       @relation(fields: [fundId], references: [id], onDelete: Cascade)
  wealthGroup WealthGroup? @relation(fields: [wealthGroupId], references: [id])

  @@unique([wealthGroupId, fundId])
}

enum BufferMethod {
  VS_UNFUNDED_PCT
  VS_PROJECTED_CALLS
}

enum AlertSeverity {
  INFO
  WARN
  CRITICAL
}

model ClientSleeve {
  id                  String       @id @default(cuid())
  clientId            String       @unique
  name                String
  targetPct           Float?       // 0–1
  cashBufferPct       Float        @default(0.05) // 0–1
  bufferMethod        BufferMethod @default(VS_UNFUNDED_PCT)
  bufferPctOfUnfunded Float        @default(0.10) // 0–1
  bufferMonthsForward Int          @default(6)
  alertEnabled        Boolean      @default(true)
  sellWaterfallJson   String       @default("[]") // JSON: ordered ProductType[] or taxonomy node names
  buyWaterfallJson    String       @default("[]") // JSON: ordered ProductType[] or taxonomy node names
  minTradeAmount      Float        @default(1000)
  createdAt           DateTime     @default(now())

  client          Client                  @relation(fields: [clientId], references: [id])
  commitments     ClientCommitment[]
  liquidPositions SleeveLiquidPosition[]
  alerts          SleeveAlert[]
  recommendations SleeveRecommendation[]
}

model SleeveAlert {
  id             String        @id @default(cuid())
  clientSleeveId String
  severity       AlertSeverity
  message        String
  isResolved     Boolean       @default(false)
  createdAt      DateTime      @default(now())

  sleeve ClientSleeve @relation(fields: [clientSleeveId], references: [id], onDelete: Cascade)
}

enum RecommendationKind {
  RAISE_LIQUIDITY
  INVEST_EXCESS
}

enum RecommendationAction {
  SELL
  BUY
}

enum ApprovalStatus {
  DRAFT
  ADVISER_APPROVED
  CLIENT_APPROVED
  REJECTED
}

enum ApprovalAction {
  APPROVE
  REJECT
}

model SleeveRecommendation {
  id               String             @id @default(cuid())
  clientSleeveId   String
  kind             RecommendationKind
  summary          String
  status           ApprovalStatus     @default(DRAFT)
  adviserApprovedAt DateTime?
  clientApprovedAt  DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?
  createdAt        DateTime           @default(now())

  sleeve ClientSleeve              @relation(fields: [clientSleeveId], references: [id], onDelete: Cascade)
  legs   SleeveRecommendationLeg[]
  events ApprovalEvent[]
}

model ApprovalEvent {
  id               String           @id @default(cuid())
  recommendationId String
  action           ApprovalAction
  actorUserId      String
  actorRole        String
  note             String?
  createdAt        DateTime         @default(now())

  recommendation SleeveRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
}

model SleeveRecommendationLeg {
  id               String               @id @default(cuid())
  recommendationId String
  action           RecommendationAction
  productId        String
  amount           Float
  reason           String

  recommendation SleeveRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  product        Product              @relation(fields: [productId], references: [id])
}

// ── Simulated Execution ──────────────────────────────────

enum ExecutionStatus {
  CREATED
  SUBMITTED
  PARTIALLY_FILLED
  FILLED
  REJECTED
  CANCELLED
}

enum OrderSource {
  SLEEVE_RECOMMENDATION
  REBALANCE_PLAN
}

enum OrderSide {
  BUY
  SELL
}

model Order {
  id        String          @id @default(cuid())
  clientId  String
  source    OrderSource
  sourceId  String          // recommendation ID
  productId String
  side      OrderSide
  amount    Float
  status    ExecutionStatus @default(CREATED)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  client  Client       @relation(fields: [clientId], references: [id])
  product Product      @relation(fields: [productId], references: [id])
  events  OrderEvent[]
}

model OrderEvent {
  id        String          @id @default(cuid())
  orderId   String
  status    ExecutionStatus
  note      String?
  createdAt DateTime        @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ClientCommitment {
  id                  String    @id @default(cuid())
  clientSleeveId      String
  fundId              String
  commitmentAmount    Float
  fundedAmount        Float     @default(0)
  navAmount           Float     @default(0)
  distributionsAmount Float     @default(0)
  latestNavDate       DateTime?
  createdAt           DateTime  @default(now())

  sleeve ClientSleeve @relation(fields: [clientSleeveId], references: [id], onDelete: Cascade)
  fund   PMFund       @relation(fields: [fundId], references: [id])

  cashflowEvents          ClientFundCashflowEvent[]
  navPoints               ClientFundNAVPoint[]
  scenario                ClientCommitmentScenario?
  distributionAllocations PMFundDistributionAllocation[]
}

model ClientFundCashflowEvent {
  id                 String            @id @default(cuid())
  clientCommitmentId String
  type               CashflowEventType
  eventDate          DateTime
  amount             Float
  currency           String            @default("AUD")
  createdAt          DateTime          @default(now())

  commitment ClientCommitment @relation(fields: [clientCommitmentId], references: [id], onDelete: Cascade)

  @@index([clientCommitmentId, eventDate])
}

model ClientFundNAVPoint {
  id                 String   @id @default(cuid())
  clientCommitmentId String
  date               DateTime
  navAmount          Float
  currency           String   @default("AUD")
  createdAt          DateTime @default(now())

  commitment ClientCommitment @relation(fields: [clientCommitmentId], references: [id], onDelete: Cascade)

  @@index([clientCommitmentId, date])
}

model ClientCommitmentScenario {
  id                 String   @id @default(cuid())
  clientCommitmentId String   @unique
  selectedTemplateId String
  note               String?
  updatedAt          DateTime @updatedAt

  commitment       ClientCommitment     @relation(fields: [clientCommitmentId], references: [id], onDelete: Cascade)
  selectedTemplate PMProjectionTemplate @relation(fields: [selectedTemplateId], references: [id])
}

model SleeveLiquidPosition {
  id             String   @id @default(cuid())
  clientSleeveId String
  productId      String
  marketValue    Float
  createdAt      DateTime @default(now())

  sleeve  ClientSleeve @relation(fields: [clientSleeveId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

// ── Stress Testing ──────────────────────────────────────

model StressScenario {
  id              String   @id @default(cuid())
  name            String
  description     String?
  createdByUserId String
  createdAt       DateTime @default(now())

  createdBy User          @relation(fields: [createdByUserId], references: [id])
  shocks    StressShock[]
  runs      StressRun[]
}

model StressShock {
  id              String @id @default(cuid())
  scenarioId      String
  taxonomyNodeId  String
  shockPct        Float  // e.g. -0.30 for -30%

  scenario StressScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  node     TaxonomyNode   @relation(fields: [taxonomyNodeId], references: [id])

  @@unique([scenarioId, taxonomyNodeId])
}

model StressRun {
  id           String   @id @default(cuid())
  scenarioId   String
  runByUserId  String
  runAt        DateTime @default(now())

  scenario StressScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  runBy    User           @relation(fields: [runByUserId], references: [id])
  results  StressResult[]
}

model StressResult {
  id                String @id @default(cuid())
  stressRunId       String
  clientId          String
  estimatedImpactPct Float  // e.g. -0.15 for -15%
  detailsJson       String // JSON breakdown

  run    StressRun @relation(fields: [stressRunId], references: [id], onDelete: Cascade)
  client Client    @relation(fields: [clientId], references: [id])
}

// ── Rebalance ───────────────────────────────────────────

enum RebalanceStatus {
  DRAFT
  ADVISER_APPROVED
  CLIENT_APPROVED
  REJECTED
}

enum RebalanceSide {
  BUY
  SELL
}

enum RebalanceApprovalAction {
  APPROVE
  REJECT
}

model RebalancePlan {
  id        String          @id @default(cuid())
  clientId  String
  saaId     String
  status    RebalanceStatus @default(DRAFT)
  summaryJson String        // JSON: before/after drift summary
  createdAt DateTime        @default(now())

  client Client           @relation(fields: [clientId], references: [id])
  saa    SAA              @relation(fields: [saaId], references: [id])
  trades RebalanceTrade[]
  events RebalanceApprovalEvent[]
}

model RebalanceTrade {
  id        String        @id @default(cuid())
  planId    String
  productId String
  side      RebalanceSide
  amount    Float
  reason    String

  plan    RebalancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
}

model RebalanceApprovalEvent {
  id          String                  @id @default(cuid())
  planId      String
  action      RebalanceApprovalAction
  actorUserId String
  actorRole   String
  note        String?
  createdAt   DateTime                @default(now())

  plan RebalancePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// ── Capital Market Assumptions ──────────────────────────

enum CMASetStatus {
  DRAFT
  ACTIVE
  RETIRED
}

model CMASet {
  id              String       @id @default(cuid())
  name            String
  description     String?
  isDefault       Boolean      @default(false)
  status          CMASetStatus @default(DRAFT)
  effectiveDate   DateTime?
  riskFreeRatePct Float        @default(0.03) // annual, e.g. 0.03 for 3%
  wealthGroupId   String?
  createdByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  wealthGroup      WealthGroup?         @relation(fields: [wealthGroupId], references: [id])
  createdBy        User                 @relation(fields: [createdByUserId], references: [id])
  assumptions      CMAAssumption[]
  correlations     CMACorrelation[]
  clientSelections ClientCMASelection[]
}

model CMAAssumption {
  id              String @id @default(cuid())
  cmaSetId        String
  taxonomyNodeId  String
  expReturnPct    Float  // e.g. 0.08 for 8%
  volPct          Float  // e.g. 0.15 for 15%
  incomeYieldPct  Float  @default(0) // annual income/yield, e.g. 0.04 for 4%

  cmaSet CMASet       @relation(fields: [cmaSetId], references: [id], onDelete: Cascade)
  node   TaxonomyNode @relation(fields: [taxonomyNodeId], references: [id])

  @@unique([cmaSetId, taxonomyNodeId])
}

model CMACorrelation {
  id        String   @id @default(cuid())
  cmaSetId  String
  nodeIdA   String
  nodeIdB   String
  corr      Float    // -1 to 1
  createdAt DateTime @default(now())

  cmaSet CMASet @relation(fields: [cmaSetId], references: [id], onDelete: Cascade)

  @@unique([cmaSetId, nodeIdA, nodeIdB])
  @@index([cmaSetId])
}

model ClientCMASelection {
  id        String   @id @default(cuid())
  clientId  String   @unique
  cmaSetId  String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  cmaSet CMASet @relation(fields: [cmaSetId], references: [id])
}

// ── Liquidity Profiles ──────────────────────────────────

enum LiquidityTier {
  LISTED
  FUND_LIQUID
  FUND_SEMI_LIQUID
  PRIVATE
  LOCKED
}

enum LiquidityOverrideSource {
  PLATFORM_SUPER_ADMIN
}

model LiquidityProfile {
  id                 String        @id @default(cuid())
  tier               LiquidityTier
  horizonDays        Int           // e.g. 2, 30, 90, 365, 730
  stressedHaircutPct Float         // e.g. 0.02 for 2%
  noticeDays         Int?
  redeemFrequency    String?       // e.g. "Daily", "Monthly", "Quarterly"
  gatePctPerPeriod   Float?        // e.g. 0.25 for 25%
  gatePeriodDays     Int?          // e.g. 90
  gateOrSuspendRisk  Boolean       @default(false)
  lockupEndDate      DateTime?
  createdAt          DateTime      @default(now())

  taxonomyDefaults    TaxonomyLiquidityDefault[]
  productOverrides    ProductLiquidityOverride[]
  adviserOverrides    AdviserLiquidityOverride[]
}

model TaxonomyLiquidityDefault {
  id                 String   @id @default(cuid())
  taxonomyNodeId     String
  liquidityProfileId String
  wealthGroupId      String?
  createdAt          DateTime @default(now())

  node        TaxonomyNode     @relation(fields: [taxonomyNodeId], references: [id], onDelete: Cascade)
  profile     LiquidityProfile @relation(fields: [liquidityProfileId], references: [id], onDelete: Cascade)
  wealthGroup WealthGroup?     @relation(fields: [wealthGroupId], references: [id])

  @@unique([taxonomyNodeId, wealthGroupId])
}

model ProductLiquidityOverride {
  id                 String                  @id @default(cuid())
  productId          String                  @unique
  liquidityProfileId String
  source             LiquidityOverrideSource @default(PLATFORM_SUPER_ADMIN)
  createdAt          DateTime                @default(now())

  product Product          @relation(fields: [productId], references: [id])
  profile LiquidityProfile @relation(fields: [liquidityProfileId], references: [id], onDelete: Cascade)
}

model AdviserLiquidityOverride {
  id                 String   @id @default(cuid())
  adviserId          String
  productId          String
  liquidityProfileId String
  createdAt          DateTime @default(now())

  adviser Adviser          @relation(fields: [adviserId], references: [id], onDelete: Cascade)
  product Product          @relation(fields: [productId], references: [id])
  profile LiquidityProfile @relation(fields: [liquidityProfileId], references: [id], onDelete: Cascade)

  @@unique([adviserId, productId])
}

// ── Liquidity Stress Testing ────────────────────────────

model LiquidityStressScenario {
  id              String   @id @default(cuid())
  name            String
  description     String?
  isDefault       Boolean  @default(false)
  createdByUserId String
  createdAt       DateTime @default(now())

  createdBy User                    @relation(fields: [createdByUserId], references: [id])
  rules     LiquidityStressRule[]
  runs      LiquidityStressRun[]
}

model LiquidityStressRule {
  id                     String @id @default(cuid())
  scenarioId             String
  horizonDays            Int    // 30, 90, 365
  extraCashDemandPct     Float  @default(0) // 0–1
  extraCashDemandAmount  Float  @default(0) // absolute $

  scenario LiquidityStressScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, horizonDays])
}

model LiquidityStressRun {
  id         String   @id @default(cuid())
  scenarioId String
  runByUserId String
  runAt      DateTime @default(now())

  scenario LiquidityStressScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  runBy    User                    @relation(fields: [runByUserId], references: [id])
  results  LiquidityStressResult[]
}

model LiquidityStressResult {
  id                 String @id @default(cuid())
  runId              String
  clientId           String
  horizonDays        Int
  availableLiquidity Float
  requiredLiquidity  Float
  coverageRatio      Float
  shortfall          Float
  detailsJson        String @default("{}")

  run    LiquidityStressRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  client Client             @relation(fields: [clientId], references: [id])

  @@index([runId, clientId])
}
