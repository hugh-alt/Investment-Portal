generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ADVISER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role
  createdAt DateTime @default(now())

  adviser    Adviser?
  taxonomies Taxonomy[]
}

model Adviser {
  id        String   @id @default(cuid())
  userId    String   @unique
  firmName  String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  clients Client[]
}

model Client {
  id        String   @id @default(cuid())
  adviserId String
  name      String
  createdAt DateTime @default(now())

  adviser Adviser @relation(fields: [adviserId], references: [id])
}

// ── Taxonomy ────────────────────────────────────────────

enum TaxonomyNodeType {
  RISK
  LIQUIDITY
  ASSET_CLASS
  SUB_ASSET
}

model Taxonomy {
  id              String         @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime       @default(now())
  createdByUserId String

  createdBy User           @relation(fields: [createdByUserId], references: [id])
  nodes     TaxonomyNode[]
}

model TaxonomyNode {
  id         String           @id @default(cuid())
  taxonomyId String
  parentId   String?
  name       String
  nodeType   TaxonomyNodeType
  sortOrder  Int              @default(0)

  taxonomy Taxonomy       @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  parent   TaxonomyNode?  @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children TaxonomyNode[] @relation("NodeTree")
}
