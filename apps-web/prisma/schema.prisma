generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ADVISER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role
  createdAt DateTime @default(now())

  adviser    Adviser?
  taxonomies Taxonomy[]
}

model Adviser {
  id        String   @id @default(cuid())
  userId    String   @unique
  firmName  String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  clients Client[]
}

model Client {
  id        String   @id @default(cuid())
  adviserId String
  name      String
  createdAt DateTime @default(now())

  adviser  Adviser   @relation(fields: [adviserId], references: [id])
  accounts Account[]
}

// ── Platform / Holdings ─────────────────────────────────

enum Platform {
  HUB24
  NETWEALTH
  CFS
}

enum ProductType {
  DIRECT
  MANAGED_PORTFOLIO
  FUND
  ETF
}

model Account {
  id          String   @id @default(cuid())
  clientId    String
  platform    Platform
  accountName String
  createdAt   DateTime @default(now())

  client   Client    @relation(fields: [clientId], references: [id])
  holdings Holding[]
}

model Product {
  id        String      @id @default(cuid())
  name      String
  type      ProductType
  createdAt DateTime    @default(now())

  holdings              Holding[]
  lookthroughUnderlying LookthroughHolding[] @relation("UnderlyingProduct")
  taxonomyMaps          ProductTaxonomyMap[]
}

model Holding {
  id         String   @id @default(cuid())
  accountId  String
  productId  String
  marketValue Float
  units      Float?
  price      Float?
  asAtDate   DateTime @default(now())

  account              Account              @relation(fields: [accountId], references: [id])
  product              Product              @relation(fields: [productId], references: [id])
  lookthroughHoldings  LookthroughHolding[]
}

model LookthroughHolding {
  id                    String @id @default(cuid())
  holdingId             String
  underlyingProductId   String
  underlyingMarketValue Float
  weight                Float

  holding            Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)
  underlyingProduct  Product @relation("UnderlyingProduct", fields: [underlyingProductId], references: [id])
}

// ── Taxonomy Mapping ─────────────────────────────────────

enum MappingScope {
  FIRM_DEFAULT
  ADVISER_OVERRIDE
  CLIENT_OVERRIDE
}

model ProductTaxonomyMap {
  id         String       @id @default(cuid())
  taxonomyId String
  productId  String
  nodeId     String
  scope      MappingScope @default(FIRM_DEFAULT)
  adviserId  String?
  clientId   String?
  createdAt  DateTime     @default(now())

  taxonomy Taxonomy     @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])
  node     TaxonomyNode @relation(fields: [nodeId], references: [id])

  @@unique([taxonomyId, productId, scope, adviserId, clientId])
}

// ── Taxonomy ────────────────────────────────────────────

enum TaxonomyNodeType {
  RISK
  LIQUIDITY
  ASSET_CLASS
  SUB_ASSET
}

model Taxonomy {
  id              String         @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime       @default(now())
  createdByUserId String

  createdBy    User                 @relation(fields: [createdByUserId], references: [id])
  nodes        TaxonomyNode[]
  productMaps  ProductTaxonomyMap[]
}

model TaxonomyNode {
  id         String           @id @default(cuid())
  taxonomyId String
  parentId   String?
  name       String
  nodeType   TaxonomyNodeType
  sortOrder  Int              @default(0)

  taxonomy    Taxonomy             @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)
  parent      TaxonomyNode?        @relation("NodeTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    TaxonomyNode[]       @relation("NodeTree")
  productMaps ProductTaxonomyMap[]
}
